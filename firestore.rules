rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: campaigns
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - url: string (required, max 1000 chars)
    //   - country: string (required, max 100 chars)
    //   - createdAt: string (optional, max 100 chars)
    //   - userId: string (required, must match auth.uid)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function isValidCampaign(data) {
      return hasOnlyAllowedFields(['name', 'url', 'country', 'createdAt', 'userId']) &&
             hasRequiredFields(['name', 'url', 'country', 'userId']) &&
             isValidString('name', 1, 100) &&
             isValidString('url', 1, 1000) &&
             isValidString('country', 1, 100) &&
             isValidOptionalString('createdAt', 1, 100) &&
             request.resource.data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if false;
    }

    match /campaigns/{campaignId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidCampaign(request.resource.data);
      allow update: if isDocOwner() && isValidCampaign(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }
  }
}
